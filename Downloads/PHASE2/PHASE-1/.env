#  Do NOT commit this file to Git.
# ═══════════════════════════════════════════════════════

# ── Server ─────────────────────────────────────────────
# Port the kiosk backend runs on (default: 3000)
PORT=3000

# ── Koha Library System ────────────────────────────────
# Base URL of the Koha REST API (without trailing slash)
KOHA_BASE_URL=http://164.52.208.94:82/api/v1

# Koha API credentials (ask your library administrator)
KOHA_API_USER=jivesna
KOHA_API_PASS=library@koha123

# Koha library branch code (default: CPL = Central Public Library)
KOHA_LIBRARY_ID=CPL

# ── QR Receipt (Mobile PDF) ────────────────────────────
# Leave both blank to auto-detect LAN IP (works on same Wi-Fi only).
#
# RECEIPT_PUBLIC_BASE_URL = internet-reachable URL (e.g. via ngrok / Cloudflare Tunnel)
#   → Patrons on mobile data CAN scan the QR
#   → Example: https://your-tunnel.trycloudflare.com
#
# RECEIPT_LOCAL_BASE_URL = override LAN URL manually
#   → Only works if patron's phone is on same Wi-Fi as kiosk
#   → Example: http://192.168.1.147:3000
#
RECEIPT_PUBLIC_BASE_URL=
RECEIPT_LOCAL_BASE_URL=

# ── RFID Bridge ────────────────────────────────────────
# Port the RFID bridge process listens on (default: 3210)
RFID_BRIDGE_PORT=3210

# Set to 0 to disable RFID entirely (useful for testing without reader)
ENABLE_RFID=1

# Set to 1 to force-rebuild the RFID bridge binary on next start (rarely needed)
RFID_FORCE_REBUILD=0
